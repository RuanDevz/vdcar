generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id        String   @id @default(cuid())
  nome      String
  email     String   @unique
  senha     String
  role      Role     @default(ADMIN)
  criadoEm DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@map("usuarios")
}

model Veiculo {
  id           String   @id @default(cuid())
  nome         String
  marca        String
  modelo       String
  ano          Int
  preco        Float
  quilometragem Int
  cor          String
  combustivel  Combustivel
  cambio       Cambio
  portas       Int      @default(4)
  descricao    String?  @db.Text
  imagemPrincipal String?
  imagens      String[] @default([])
  destaque     Boolean  @default(false)
  vendido      Boolean  @default(false)
  criadoEm    DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@map("veiculos")
}

enum Role {
  ADMIN
  SUPER_ADMIN
}

enum Combustivel {
  GASOLINA
  ETANOL
  FLEX
  DIESEL
  ELETRICO
  HIBRIDO
  GNV
}

enum Cambio {
  MANUAL
  AUTOMATICO
  AUTOMATIZADO
  CVT
}
